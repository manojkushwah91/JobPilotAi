# =============================================================================
# JobPilot AI — Environment Variables
# =============================================================================
# Template: copy to .env and fill in values
# Naming convention: {CATEGORY}_{SUBSYSTEM}_{KEY}
#   CATEGORY: DB, REDIS, KAFKA, AWS, AI, JWT, etc.
# =============================================================================

# ---- Database ----
DB_URL=jdbc:postgresql://localhost:5432/jobpilot
DB_USERNAME=jobpilot
DB_PASSWORD=jobpilot_dev
DB_POOL_MAX=20

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=jobpilot-dev

# ---- AI Providers ----
AI_OPENAI_API_KEY=sk-...
AI_ANTHROPIC_API_KEY=sk-ant-...
AI_GEMINI_API_KEY=...
OLLAMA_BASE_URL=http://localhost:11434

# ---- JWT ----
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000
JWT_PUBLIC_KEY_PATH=classpath:keys/public.pem
JWT_PRIVATE_KEY_PATH=classpath:keys/private.pem

# ---- OAuth ----
OAUTH_GOOGLE_CLIENT_ID=...
OAUTH_GOOGLE_CLIENT_SECRET=...
OAUTH_LINKEDIN_CLIENT_ID=...
OAUTH_LINKEDIN_CLIENT_SECRET=...
OAUTH_GITHUB_CLIENT_ID=...
OAUTH_GITHUB_CLIENT_SECRET=...
OAUTH_MICROSOFT_CLIENT_ID=...
OAUTH_MICROSOFT_CLIENT_SECRET=...

# ---- Email ----
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG....

# ---- Storage ----
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=jobpilot-uploads

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ---- Observability ----
OTLP_ENDPOINT=http://localhost:4317

# ---- Application ----
APP_URL=http://localhost:3000
API_URL=http://localhost:8080/api/v1
CORS_ORIGINS=http://localhost:3000
