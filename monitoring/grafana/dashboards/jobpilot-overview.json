{
  "title": "JobPilot AI Overview",
  "uid": "jobpilot-overview",
  "panels": [
    {
      "title": "API Request Rate",
      "type": "timeseries",
      "targets": [{"expr": "rate(http_server_requests_seconds_count[5m])"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "targets": [{"expr": "rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "title": "Active Users",
      "type": "stat",
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count[1m]))"}],
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 8}
    },
    {
      "title": "P99 Latency",
      "type": "timeseries",
      "targets": [{"expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket[5m]))"}],
      "gridPos": {"h": 8, "w": 12, "x": 4, "y": 8}
    },
    {
      "title": "JVM Memory",
      "type": "timeseries",
      "targets": [
        {"expr": "jvm_memory_used_bytes{area=\"heap\"}"},
        {"expr": "jvm_memory_max_bytes{area=\"heap\"}"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
    },
    {
      "title": "AI Token Usage",
      "type": "timeseries",
      "targets": [{"expr": "rate(jobpilot_ai_tokens_total[5m])"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
    }
  ],
  "schemaVersion": 36,
  "version": 1
}
